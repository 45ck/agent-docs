id: PRD-001
kind: PRD
title: Product Requirements for React To-Do Demonstration
status: accepted
scope: app
owner: Product
date: 2026-03-03
canonicalKey: todo-app-prd
tags[3]: demo,frontend,requirements
dependsOn[1]: PLAN-001
supersedes[0]:

  title: Agent Docs React Todo Example Plan
  status: accepted
  scope: app
  owner: Product & Docs Team
  date: 2026-03-03
  canonicalKey: todo-app-plan
  tags[4]: demo,example,docs,planning
  dependsOn[0]:

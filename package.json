{
  "name": "@45ck/agent-docs",
  "version": "0.4.0",
  "description": "Canonical agent-docs package for structured planning artifacts and markdown governance",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/45ck/agent-docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/45ck/agent-docs.git"
  },
  "bugs": {
    "url": "https://github.com/45ck/agent-docs/issues"
  },
  "keywords": [
    "documentation",
    "governance",
    "planning",
    "agent",
    "markdown",
    "structure",
    "adr",
    "open-source",
    "quality-gates"
  ],
  "license": "MIT",
  "author": "45ck",
  "bin": {
    "agent-docs": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "templates",
    ".agent-docs/hooks",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/v2/schema.sql','dist/v2/schema.sql')\"",
    "check": "node dist/index.js check",
    "generate": "node dist/index.js generate",
    "doctor": "node dist/index.js doctor",
    "init": "node dist/index.js init",
    "install-gates": "node dist/index.js install-gates",
    "test": "node --test dist/test/*.test.js",
    "pack:smoke": "node scripts/pack-smoke.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@45ck/noslop": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@45ck/noslop": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "directories": {
    "doc": "docs",
    "example": "example"
  }
}
